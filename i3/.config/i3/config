# i3 config file (v4)
# Standalone i3wm setup for Ubuntu
# Adapted from EndeavourOS i3wm reference

#######################
# config starts here: #
#######################

# Font for window titles and bar
font pango: Noto Sans Regular 8, JetBrainsMono Nerd Font 8

# set the mod key to the winkey:
set $mod Mod4

#####################
# workspace layout: #
#####################

workspace_layout default

##############################
# extra options for windows: #
##############################

# border indicator on windows:
new_window pixel 1

# Set inner/outer gaps
gaps inner 6
gaps outer 3
# gaps top handled by _NET_WM_STRUT_PARTIAL on the i3more dock window

# Use Mouse+$mod to drag floating windows
floating_modifier $mod
mouse_warping none

# move tiling windows via drag & drop by left-clicking into the title bar
tiling_drag modifier titlebar

# switch/iterate between workspaces
bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

######################################
# keybindings for different actions: #
######################################

# start a terminal
bindsym $mod+Return exec --no-startup-id alacritty

# kill focused window
bindsym $mod+q kill

# exit-menu (i3More power menu)
bindsym $mod+Shift+e exec --no-startup-id /opt/i3more/bin/i3more-power

# Lock the system
bindsym $mod+l exec --no-startup-id /opt/i3more/bin/i3more-lock

# reload the configuration file
bindsym $mod+Shift+c reload

# restart i3 inplace
bindsym $mod+Shift+r restart

# keybinding viewer (i3More)
bindsym F1 exec --no-startup-id /opt/i3more/bin/i3more-keyhint

# Backlight control (i3More)
bindsym XF86MonBrightnessUp exec --no-startup-id /opt/i3more/bin/i3more-audio brightness-up
bindsym XF86MonBrightnessDown exec --no-startup-id /opt/i3more/bin/i3more-audio brightness-down

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+b focus up
bindsym $mod+o focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# focus previously focused window (MRU)
bindsym Mod1+Tab exec --no-startup-id /opt/i3more/bin/i3more-back

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+b move up
bindsym $mod+Shift+o move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+h split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout — focused parent only (built-in i3)
bindsym $mod+s layout stacking
bindsym $mod+g layout tabbed
bindsym $mod+e layout toggle split

# change workspace-wide layout — cascade via i3more-layout (every nested
# container in the focused workspace adopts the chosen layout)
bindsym $mod+Ctrl+h exec --no-startup-id /opt/i3more/bin/i3more-layout splith
bindsym $mod+Ctrl+v exec --no-startup-id /opt/i3more/bin/i3more-layout splitv
bindsym $mod+Ctrl+g exec --no-startup-id /opt/i3more/bin/i3more-layout tabbed
bindsym $mod+Ctrl+e exec --no-startup-id /opt/i3more/bin/i3more-layout toggle

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# app launcher (i3More)
bindsym $mod+space exec --no-startup-id /opt/i3more/bin/i3more-launcher

# focus the parent container
bindsym $mod+a focus parent

# open new empty workspace (i3More)
bindsym $mod+Shift+n exec --no-startup-id /opt/i3more/bin/i3more-workspace open-empty

# move focused container to next sequential workspace (i3more)
bindsym $mod+Shift+m exec --no-startup-id /opt/i3more/bin/i3more-workspace move-next

# resize window
mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym odiaeresis resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

##################
# Multimedia Keys #
##################

# volume
bindsym XF86AudioRaiseVolume exec --no-startup-id /opt/i3more/bin/i3more-audio volume-up
bindsym XF86AudioLowerVolume exec --no-startup-id /opt/i3more/bin/i3more-audio volume-down

# gradular volume control
bindsym $mod+XF86AudioRaiseVolume exec --no-startup-id /opt/i3more/bin/i3more-audio volume-up
bindsym $mod+XF86AudioLowerVolume exec --no-startup-id /opt/i3more/bin/i3more-audio volume-down

# mute
bindsym XF86AudioMute exec --no-startup-id /opt/i3more/bin/i3more-audio volume-mute

# mic mute toggle (i3More)
bindsym XF86AudioMicMute exec --no-startup-id /opt/i3more/bin/i3more-audio mic-mute

# audio control (i3More)
bindsym XF86AudioPlay exec --no-startup-id /opt/i3more/bin/i3more-audio play-pause
bindsym XF86AudioNext exec --no-startup-id /opt/i3more/bin/i3more-audio next
bindsym XF86AudioPrev exec --no-startup-id /opt/i3more/bin/i3more-audio prev

# toggle between audio devices for output
bindsym $mod+p exec --no-startup-id /opt/i3more/bin/i3more-audio audio-switch

## App shortcuts
bindsym $mod+w exec --no-startup-id zen
bindsym $mod+n exec --no-startup-id /usr/bin/thunar
bindsym Print exec --no-startup-id scrot ~/%Y-%m-%d-%T-screenshot.png && notify-send "Screenshot saved to ~/$(date +"%Y-%m-%d-%T")-screenshot.png"

# Monitor layout editor (arandr)
bindsym $mod+m exec --no-startup-id arandr

# Power Profiles menu switcher (i3More)
bindsym $mod+Shift+p exec --no-startup-id /opt/i3more/bin/i3more-power-profile

# Translator EN ↔ DE (i3More)
bindsym $mod+Shift+t exec --no-startup-id /opt/i3more/bin/i3more-translate
bindsym $mod+Ctrl+t exec --no-startup-id /opt/i3more/bin/i3more-popup-translate

##########################################
# configuration for workspace behaviour: #
##########################################

# Define names for default workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"


##################
# floating rules #
##################

for_window [class="Yad" instance="yad"] floating enable
for_window [class="Galculator" instance="galculator"] floating enable
for_window [class="Blueberry.py" instance="blueberry.py"] floating enable
for_window [class="Pavucontrol" instance="pavucontrol"] floating enable
for_window [class="qt5ct" instance="qt5ct"] floating enable
for_window [class="Bluetooth-sendto" instance="bluetooth-sendto"] floating enable
for_window [window_role="About"] floating enable
for_window [title="i3More-launcher"] floating enable, border none
for_window [title="i3More-translate"] floating enable, border pixel 1, resize set 400 420
for_window [title="i3more-popup-translate"] floating enable, border pixel 0
for_window [title="i3More-power"] floating enable, border pixel 1
for_window [title="i3More-power-profile"] floating enable, border pixel 1
for_window [title="i3More-keyhint"] floating enable, border pixel 1
for_window [title="i3More-window"] floating enable, border pixel 1
# i3More-navigator uses _NET_WM_WINDOW_TYPE_DOCK — i3 auto-handles positioning, no-focus, sticky
no_focus [title="i3More-navigator"]
for_window [title="i3more-notify-*"] floating enable, border none
for_window [title="i3more-notification-panel"] floating enable, border pixel 1

# set border of floating window
for_window [class="urxvt"] border pixel 1

#############################################
# autostart applications/services on login: #
#############################################

# apply saved monitor layout
exec --no-startup-id ~/.screenlayout/home.sh

# polkit agent (Ubuntu path)
exec --no-startup-id /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1

# dex execute .desktop files
exec --no-startup-id dex --autostart --environment i3

# compositor
exec --no-startup-id picom --config ~/.config/picom/picom.conf

# wallpaper is managed by i3more (background widget)

# set powersavings for display:
exec --no-startup-id xset s 480 dpms 600 600 600

# lock in case after sleep
exec --no-startup-id xss-lock -l -- /opt/i3more/bin/i3more-lock

# Desktop notifications (handled by i3more)
# exec --no-startup-id /usr/bin/dunst

# autotiling
exec_always --no-startup-id i3-auto-tiling

# dynamic workspace icons (disabled — replaced by i3more)
# exec_always --no-startup-id i3-workspace-names-daemon

# auto-renumber workspaces sequentially on close (disabled — conflicts with i3more)
# exec_always --no-startup-id ~/.config/i3/scripts/auto-renumber-workspaces.sh

# i3more workspace navigator
exec_always --no-startup-id killall i3more 2>/dev/null; exec /opt/i3more/bin/i3more

# networkmanager-applet
exec --no-startup-id nm-applet

# bluetooth applet
exec --no-startup-id blueman-applet

# EWW bar (disabled — causes high CPU usage)
# exec_always --no-startup-id bash -c 'eww close-all 2>/dev/null; eww ping 2>/dev/null || GTK_THEME=Yaru-sage-dark eww daemon; sleep 1; eww open-many bar bar2; pkill -f fullscreen-monitor.sh 2>/dev/null; sleep 0.5; ~/.config/eww/scripts/fullscreen-monitor.sh &'

# Apps
exec --no-startup-id slack

######################################
# color settings for bar and windows #
######################################

# Define colors variables:
set $darkbluetrans  #08052be6
set $darkblue       #08052b
set $lightblue      #5294e2
set $urgentred      #e53935
set $white          #ffffff
set $black          #000000
set $purple         #e345ff
set $darkgrey       #383c4a
set $grey           #b0b5bd
set $mediumgrey     #8b8b8b
set $yellowbrown    #e1b700

# define colors for windows:
#class                      border      bground     text        indicator   child_border
client.focused              $lightblue  $darkblue   $white      $mediumgrey $mediumgrey
client.unfocused            $darkblue   $darkblue   $grey       $darkgrey   $darkgrey
client.focused_inactive     $darkblue   $darkblue   $grey       $black      $black
client.urgent               $urgentred  $urgentred  $white      $yellowbrown    $yellowbrown

#####################################
# Application menu:                 #
#####################################

## app launcher (i3More)
bindsym $mod+d exec --no-startup-id /opt/i3more/bin/i3more-launcher

## window switcher (i3More)
bindsym $mod+t exec --no-startup-id /opt/i3more/bin/i3more-window

# >>> whisper-stt indicator rule >>>
for_window [title="^whisper-stt$"] floating enable, sticky enable, border none
# <<< whisper-stt indicator rule <<<

# >>> whisper-stt bindings >>>
bindsym            F9 exec --no-startup-id whisperctl start
bindsym --release  F9 exec --no-startup-id whisperctl stop
# <<< whisper-stt bindings <<<
